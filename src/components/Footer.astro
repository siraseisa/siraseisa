					></path>
				</svg>
			</a>
		)}
		{SOCIAL_LINKS.email && (
			<a href={SOCIAL_LINKS.email} target="_blank" rel="noopener noreferrer">
				<span class="sr-only">Email</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32">
					<path
						fill="currentColor"
						d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383l-4.708 2.825L15 11.105V5.383zm-.034 6.876L8.029 8.92 1.034 12.26A1 1 0 0 0 2 13h12a1 1 0 0 0 .966-.74zM1 11.105l4.708-2.897L1 5.383v5.722z"
					></path>
				</svg>
			</a>
		)}
	</div>
</footer>

<style>
	footer {
		padding: 1rem 1rem;
		background-color: var(--bg-primary);
		border-top: 1px solid var(--border-color);
		color: var(--text-muted);
		text-align: center;
		font-size: 0.875rem;
		transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1.5rem;
		margin-top: 1.5rem;
	}
	.social-links a {
		text-decoration: none;
		color: var(--text-muted);
		transition: color 0.2s ease;
	}
	.social-links a:hover {
		color: var(--accent);
	}
</style>
